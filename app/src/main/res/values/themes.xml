<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Usamos .NoActionBar para termos controle total da Toolbar -->
    <style name="Theme.HamburgueriaZ" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Cores principais -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- FORÇAR TELA CHEIA: Esconde a barra de status (relógio, bateria, etc) -->
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>

        <!-- Cor da barra de estado (ignorado se windowFullscreen for true, mas mantemos por segurança) -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:windowBackground">@color/white</item>
    </style>

    <!-- Estilo para os títulos das seções -->
    <style name="EstiloTexto">
        <!-- Propriedades de dimensão -->
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>

        <!-- Alinhamento vertical -->
        <item name="android:gravity">center_vertical</item>

        <!-- Formatação de texto: Todas as letras maiúsculas -->
        <item name="android:textAllCaps">true</item>

        <!-- Tamanho da fonte em SP (padrão Android para acessibilidade) -->
        <item name="android:textSize">15sp</item>

        <!-- Espaçamento interno superior e inferior em DP -->
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>

        <!-- Cor e estilo personalizados para os títulos -->
        <item name="android:textColor">#212121</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>